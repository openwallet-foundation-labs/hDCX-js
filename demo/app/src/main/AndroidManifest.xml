<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- BLE + NFC proximity permissions/features and the HCE engagement service are contributed by the
         com.hopae.eudi.android:proximity library manifest (merged in). -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DynamicColors.DayNight">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- OpenID4VCI authorization-code redirect (WalletConfig.issuance.redirectUri). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="eu.europa.ec.euidi" android:host="authorization" />
            </intent-filter>
            <!-- Credential-offer and presentation invocation links (match the EUDI reference wallet). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="openid-credential-offer" />
                <data android:scheme="haip-vci" />
                <data android:scheme="openid4vp" />
                <data android:scheme="eudi-openid4vp" />
                <data android:scheme="mdoc-openid4vp" />
                <data android:scheme="haip-vp" />
            </intent-filter>
        </activity>
        <activity
            android:name=".PortraitCaptureActivity"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/zxing_CaptureTheme"
            android:exported="false" />
        <!-- Digital Credentials API (Credential Manager) request handler. -->
        <activity
            android:name=".GetCredentialActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="androidx.credentials.registry.provider.action.GET_CREDENTIAL" />
                <action android:name="androidx.identitycredentials.action.GET_CREDENTIALS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>

</manifest>

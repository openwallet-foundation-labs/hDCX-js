PORT=3200
STAGE=dev
# Postgres — the app reads this; run `pnpm migrate` (DATABASE_URL set) to apply the schema.
DATABASE_URL=postgresql://wp:wp@localhost:5432/wallet_provider
# Wallet Provider issuer/base URL: the `iss` of issued JWTs and the instance-PoP audience.
# With the global prefix the app serves under /wp, so include it.
WP_ISSUER=http://localhost:3200/wp
# pino log level (optional; default: debug in non-prod, info in prod)
# LOG_LEVEL=debug
# Real Play Integrity verification (optional — omit to use the dev-integrity:<nonce> stub):
# PLAY_INTEGRITY_PACKAGE_NAME=com.hopae.axle.wallet
# Android Key Attestation trust anchors default to pinned Google roots; override only if needed:
# ANDROID_ATTESTATION_ROOTS='<PEM bundle of root certs>'
# ANDROID_ATTESTATION_STATUS_URL=https://android.googleapis.com/attestation/status
# Service-account key as a single-line JSON *string* (not a file path); injected as a k8s secret.
# Use compact JSON (jq -c) and single quotes so private_key's \n escapes stay intact:
#   GOOGLE_SERVICE_ACCOUNT_JSON='<paste `jq -c . service-account.json` output here>'
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
